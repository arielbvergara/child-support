NEXT_PUBLIC_API_URL=http://localhost:3001

# --- Sentry Error Monitoring ---
# DSN for runtime error reporting. Leave empty to disable Sentry in local development.
NEXT_PUBLIC_SENTRY_DSN=
# Auth token used at BUILD TIME ONLY to upload source maps and create releases.
# Without it, errors are still captured but stack traces show minified/compiled code.
# Set this in your CI/CD environment and deployment platform (e.g. Vercel env vars).
# DO NOT set this in .env.local — it is not needed at runtime.
# Generate at sentry.io → User Auth Tokens with the project:releases scope.
SENTRY_AUTH_TOKEN=
