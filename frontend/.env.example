NEXT_PUBLIC_API_URL=http://localhost:3001

# --- Business & Professional Info ---
# Real business address displayed in the footer, contact page, and LocalBusiness JSON-LD schema.
NEXT_PUBLIC_BUSINESS_ADDRESS_LINE_1=
NEXT_PUBLIC_BUSINESS_POSTAL_CODE=
NEXT_PUBLIC_BUSINESS_CITY=
# Contact details used in the footer, contact page, and LocalBusiness JSON-LD schema.
NEXT_PUBLIC_BUSINESS_PHONE=
NEXT_PUBLIC_BUSINESS_EMAIL=
# Full name of the professional used in the Person JSON-LD schema on the About page.
NEXT_PUBLIC_PROFESSIONAL_NAME=
# Public URL of the professional's headshot (used in Person JSON-LD schema image field).
NEXT_PUBLIC_PROFESSIONAL_PHOTO_URL=
# LinkedIn public profile URL (used in Person JSON-LD schema sameAs).
NEXT_PUBLIC_PROFESSIONAL_LINKEDIN=
# BIG register public profile URL (used in Person JSON-LD schema sameAs).
NEXT_PUBLIC_PROFESSIONAL_BIG_REGISTER=

# --- Sentry Error Monitoring ---
# DSN for runtime error reporting. Leave empty to disable Sentry in local development.
NEXT_PUBLIC_SENTRY_DSN=
# Auth token used at BUILD TIME ONLY to upload source maps and create releases.
# Without it, errors are still captured but stack traces show minified/compiled code.
# Set this in your CI/CD environment and deployment platform (e.g. Vercel env vars).
# DO NOT set this in .env.local — it is not needed at runtime.
# Generate at sentry.io → User Auth Tokens with the project:releases scope.
SENTRY_AUTH_TOKEN=
