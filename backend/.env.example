PORT=3001
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# --- Email (Resend) ---
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@yourdomain.com
# Email address that receives new contact form submissions.
# NOTE: With Resend's free plan, only verified email addresses can receive mail.
# Verify a custom domain at https://resend.com/docs/dashboard/domains/introduction
# to lift this restriction and re-enable visitor auto-replies.
CONTACT_OWNER_EMAIL=info@yourdomain.com

# --- Google Sheets Logging ---
GOOGLE_SHEETS_ID=your-spreadsheet-id-from-url
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nABC123...\n-----END PRIVATE KEY-----\n"

# --- Google Calendar Booking ---
# Calendar ID where appointment events are created.
# Share the professional's Google Calendar with GOOGLE_SERVICE_ACCOUNT_EMAIL
# and grant "Make changes to events" permission before enabling this.
# Use "primary" for the default calendar, or the calendar's email address for a specific one.
GOOGLE_CALENDAR_ID=primary

# --- Sentry Error Monitoring ---
# DSN for runtime error reporting. Leave empty to disable Sentry in local development.
SENTRY_DSN=
